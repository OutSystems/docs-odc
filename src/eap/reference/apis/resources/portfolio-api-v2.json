              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "description": "Patch request with new name",
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/PatchPortfolioRequest"
                  }
                ],
                "additionalProperties": false,
                "description": "Request to update a portfolio's name"
              }
            },
            "application/*+json": {
              "schema": {
