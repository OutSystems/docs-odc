  "components": {
    "schemas": {
      "AddOn": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "AddOn Title",
            "nullable": true
          },
          "description": {
            "type": "string",
            "description": "AddOn description",
            "nullable": true
          },
          "documentationUrl": {
            "type": "string",
            "description": "Addon documentation Url",
            "nullable": true
          },
          "dataType": {
            "type": "string",
            "description": "Addon Data type",
            "nullable": true
          },
          "name": {
            "type": "string",
            "description": "Addon name",
            "nullable": true
          },
          "value": {
            "type": "string",
            "description": "Addon value",
            "nullable": true
          },
          "isNullable": {
            "type": "boolean",
            "description": "Defines if the addOn can have a null value"
          },
          "status": {
            "allOf": [
              {
                "$ref": "#/components/schemas/AddOnStatus"
              }
            ],
            "description": "Defines whether the addOn is active or Not"
          }
        },
        "additionalProperties": false,
        "description": "Represents the addOn information"
      },
      "AddOnStatus": {
        "enum": [
          "active",
          "inactive"
        ],
        "type": "string"
      },
      "BaseEnvironmentMeasuredEntitlement": {
        "type": "object",
        "properties": {
          "maxValue": {
            "type": "integer",
            "description": "Maximum value allowed for the environment entitlement",
            "format": "int32",
            "nullable": true
          },
          "measuredValue": {
            "type": "integer",
            "description": "Current value for the given entitlement",
            "format": "int64",
            "nullable": true
          },
          "lastUpdatedDate": {
            "type": "string",
            "description": "Last time it was updated",
            "format": "date-time",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Represents the measured entitlement information"
      },
      "EntitlementUsageItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Entitlement identifier (e.g., \"applicationObjects\").",
            "nullable": true
          },
          "name": {
            "type": "string",
            "description": "Human-readable name of the entitlement.",
            "nullable": true
          },
          "aggregation": {
            "type": "string",
            "description": "Aggregation function applied (e.g., \"avg\", \"max\", \"total\").",
            "nullable": true
          },
          "lastUpdatedDate": {
            "type": "string",
            "description": "Last time this usage data was updated.",
            "format": "date-time",
            "nullable": true
          },
          "usage": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UsageDataPoint"
            },
            "description": "Time series of usage data points.",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Represents usage data for a single entitlement type."
      },
      "EntitlementUsageItemListResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EntitlementUsageItem"
            },
            "description": "List of results.",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Represents a response containing a list of results."
      },
      "EnvironmentEntitlements": {
        "type": "object",
        "properties": {
          "addOns": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AddOn"
            },
            "description": "List of addOns in an environment",
            "nullable": true
          },
          "limits": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Limit"
            },
            "description": "List of Limits in an environment",
            "nullable": true
          },
          "users": {
            "allOf": [
              {
                "$ref": "#/components/schemas/EnvironmentUsersEntitlement"
              }
            ],
            "description": "Represents the users in an environment",
            "nullable": true
          },
          "applicationObjects": {
            "allOf": [
              {
                "$ref": "#/components/schemas/BaseEnvironmentMeasuredEntitlement"
              }
            ],
            "description": "Represents the application objects in an environment",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Represents the entitlements present in an environment"
      },
      "EnvironmentUsersEntitlement": {
        "type": "object",
        "properties": {
          "internal": {
            "allOf": [
              {
                "$ref": "#/components/schemas/BaseEnvironmentMeasuredEntitlement"
              }
            ],
            "description": "Represents the internal users of an environment",
            "nullable": true
          },
          "external": {
            "allOf": [
              {
                "$ref": "#/components/schemas/BaseEnvironmentMeasuredEntitlement"
              }
            ],
            "description": "Represents the external users of an environment",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Limit": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Limit Name",
            "nullable": true
          },
          "value": {
            "type": "string",
            "description": "Limit Value",
            "nullable": true
          },
          "description": {
            "type": "string",
            "description": "Limit Description",
            "nullable": true
          },
          "title": {
            "type": "string",
            "description": "Limit Title",
            "nullable": true
          },
          "documentationUrl": {
            "type": "string",
            "description": "Limit DocumentationUrl",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "OrganizationConfigurations": {
        "type": "object",
        "properties": {
          "areAllEmailDomainsInternal": {
            "type": "boolean",
            "description": "Defines whether all email user domains are internal or not"
          },
          "internalEmailDomains": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of email user domains to be considered as internal",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Represents the configurations for the Organization."
      },
      "OrganizationEntitlements": {
        "type": "object",
        "properties": {
          "subscriptionStartDate": {
            "type": "string",
            "description": "Date when the organization first subscribed",
            "format": "date-time"
          },
          "subscriptionEndDate": {
            "type": "string",
            "description": "Date when the organization subscription will end",
            "format": "date-time",
            "nullable": true
          },
          "adminEmailDomain": {
            "type": "string",
            "description": "Domain of the admin email",
            "nullable": true
          },
          "edition": {
            "type": "string",
            "description": "Edition",
            "nullable": true
          },
          "editionId": {
            "type": "string",
            "description": "Edition Id",
            "nullable": true
          },
          "addOns": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AddOn"
            },
            "description": "Collection of the addOns the organization subscribed to",
            "nullable": true
          },
          "limits": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Limit"
            },
            "description": "Collection of the limits the organization contracted to",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Represents the entitlements present in an organization"
      },
      "PageInfoWithTotals": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer",
            "description": "Number of results in the current page.",
            "format": "int32"
          },
          "limit": {
            "type": "integer",
            "description": "Limit of results per page.",
            "format": "int32"
          },
          "offset": {
            "type": "integer",
            "description": "Offset of the current page of results.",
            "format": "int32"
          },
          "nextPageOffset": {
            "type": "integer",
            "description": "Offset of the next page of results. Null when there is no next page.",
            "format": "int32",
            "nullable": true
          },
          "totalResults": {
            "type": "integer",
            "description": "Total of results.",
            "format": "int32"
          },
          "totalPages": {
            "type": "integer",
            "description": "Total of result pages.",
            "format": "int32",
            "readOnly": true
          }
        },
        "additionalProperties": false,
        "description": "Contains response page information including totals."
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "A URI reference that identifies the problem type.",
            "nullable": true
          },
          "title": {
            "type": "string",
            "description": "A short, human-readable summary of the problem.",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "description": "The HTTP status code applicable to the problem.",
            "format": "int32",
            "nullable": true
          },
          "detail": {
            "type": "string",
            "description": "A human-readable explanation of the error.",
            "nullable": true
          },
          "instance": {
            "type": "string",
            "description": "A URI that identifies the specific occurrence of the problem.",
            "nullable": true
          },
